generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  nickname     String    @unique
  passwordHash String? // 소셜 로그인 계정은 비밀번호 없음
  points       Int       @default(0)
  level        Int       @default(1)
  // 닉네임: 가입 후 총 3회까지 변경. nicknameConfirmed=false(구글 신규)면 최초 1회 설정은 무료.
  nicknameChanges   Int     @default(0)
  nicknameConfirmed Boolean @default(true)
  createdAt    DateTime   @default(now())
  posts        Post[]
  comments     Comment[]
  votes        Vote[]
  pointLogs    PointLog[]
  portfolio    PortfolioItem[]
  prizeWins    PrizeWin[]
  chatMessages ChatMessage[]
}

// 채팅 도배 방지 — 사용자별 버스트 카운트 + 누진 제재(밴) 상태.
// 연속 3회 → 10초, 반복 → 30초, 비정상 반복 → 1시간. 5분간 위반 없으면 단계 초기화.
model ChatLimit {
  userId      String    @id
  recentCount Int       @default(0) // 현재 버스트 윈도우 내 메시지 수
  windowStart DateTime  @default(now())
  bannedUntil DateTime? // 이 시각까지 채팅 금지
  offenses    Int       @default(0) // 누진 위반 단계 (1:10초 · 2:30초 · 3+:1시간)
  lastOffense DateTime?
  updatedAt   DateTime  @updatedAt
}

// 실시간 채팅 메시지 — 단일 공개 라운지(폴링 방식). 닉네임/레벨은 작성 시점 스냅샷으로
// 저장해 폴링마다 User 조인 없이 빠르게 조회한다.
model ChatMessage {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  nickname  String
  level     Int      @default(1)
  content   String
  createdAt DateTime @default(now())

  @@index([id])
}

// 랜덤박스 상품 — 어드민(운영진 Lv10+)이 등록/관리
model Prize {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  imageUrl    String?
  rarity      String     @default("common") // common | rare | epic | legendary (색·연출 등급)
  weight      Int        @default(100) // 추첨 가중치 — 클수록 자주 당첨
  stock       Int? // null=무제한, 숫자=남은 수량 (0이면 소진)
  active      Boolean    @default(true)
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  wins        PrizeWin[]

  @@index([active])
}

// 랜덤박스 당첨 내역
model PrizeWin {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  prize     Prize    @relation(fields: [prizeId], references: [id])
  prizeId   Int
  cost      Int // 소모 포인트
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([prizeId])
  @@index([createdAt(sort: Desc)])
}

model PortfolioItem {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  symbol    String
  quantity  Float
  buyPrice  Float // 매수 단가 (currency 기준)
  currency  String   @default("KRW") // KRW | USD
  createdAt DateTime @default(now())

  @@index([userId])
}

// 외부 API 응답 공유 캐시 — 요청 시점 외부 호출 제거(서버리스 인스턴스 간 공유)
model MarketCache {
  key       String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

// 고정창 레이트리밋 카운터 (로그인/가입 무차별 대입·남용 방지)
model RateLimit {
  key       String   @id // 예: "login:1.2.3.4" | "register:1.2.3.4"
  count     Int      @default(0)
  resetAt   DateTime
  @@index([resetAt])
}

model MarketSnapshot {
  id           Int      @id @default(autoincrement())
  btcDominance Float
  totalMcapUsd Float
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model PointLog {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  action    String // post | comment | attendance
  delta     Int
  day       String? // 출석체크용 KST 날짜 (YYYY-MM-DD)
  createdAt DateTime @default(now())

  @@unique([userId, action, day])
  @@index([action, day])
}

model Board {
  id         Int     @id @default(autoincrement())
  slug       String  @unique
  name       String
  type       String  @default("community") // community | info | forum
  coinSymbol String?
  sortOrder  Int     @default(0)
  posts      Post[]
}

model Post {
  id           Int       @id @default(autoincrement())
  board        Board     @relation(fields: [boardId], references: [id])
  boardId      Int
  author       User      @relation(fields: [userId], references: [id])
  userId       String
  title        String
  content      String
  viewCount    Int       @default(0)
  upvotes      Int       @default(0)
  downvotes    Int       @default(0)
  commentCount Int       @default(0)
  isNotice     Boolean   @default(false)
  priceAtPost  Float?
  priceSymbol  String?
  createdAt    DateTime  @default(now())
  comments     Comment[]
  votes        Vote[]

  @@index([boardId, createdAt(sort: Desc)])
  @@index([boardId, upvotes])
}

model Comment {
  id        Int      @id @default(autoincrement())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    Int
  author    User     @relation(fields: [userId], references: [id])
  userId    String
  content   String
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

model CalendarEvent {
  id          Int      @id @default(autoincrement())
  date        DateTime
  isTba       Boolean  @default(false)
  ticker      String
  title       String
  description String
  category    String // important | good | bad | neutral (색상 분류)
  groupMain   String   @default("크립토") // 주식 | 크립토 | 매크로 | 이벤트 (필터 대분류)
  groupSub    String   @default("기타") // 필터 소분류
  sourceUrl   String?
  createdAt   DateTime @default(now())

  @@index([date])
}

model KimpSnapshot {
  id        Int      @id @default(autoincrement())
  btcKrw    Float
  btcUsd    Float
  usdKrw    Float
  kimp      Float
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Vote {
  id     Int    @id @default(autoincrement())
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId Int
  user   User   @relation(fields: [userId], references: [id])
  userId String
  value  Int

  @@unique([postId, userId])
}

// 일자별 접속자 집계 (KST 기준 day = "YYYY-MM-DD") — 어드민 "금일 총 접속자"
model VisitStat {
  day       String   @id // KST 날짜 "2026-06-22"
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
}
