generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  nickname     String    @unique
  passwordHash String? // 소셜 로그인 계정은 비밀번호 없음
  points       Int       @default(0)
  level        Int       @default(1)
  createdAt    DateTime   @default(now())
  posts        Post[]
  comments     Comment[]
  votes        Vote[]
  pointLogs    PointLog[]
  portfolio    PortfolioItem[]
}

model PortfolioItem {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  symbol    String
  quantity  Float
  buyPrice  Float // 매수 단가 (currency 기준)
  currency  String   @default("KRW") // KRW | USD
  createdAt DateTime @default(now())

  @@index([userId])
}

// 외부 API 응답 공유 캐시 — 요청 시점 외부 호출 제거(서버리스 인스턴스 간 공유)
model MarketCache {
  key       String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

// 고정창 레이트리밋 카운터 (로그인/가입 무차별 대입·남용 방지)
model RateLimit {
  key       String   @id // 예: "login:1.2.3.4" | "register:1.2.3.4"
  count     Int      @default(0)
  resetAt   DateTime
  @@index([resetAt])
}

model MarketSnapshot {
  id           Int      @id @default(autoincrement())
  btcDominance Float
  totalMcapUsd Float
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model PointLog {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  action    String // post | comment | attendance
  delta     Int
  day       String? // 출석체크용 KST 날짜 (YYYY-MM-DD)
  createdAt DateTime @default(now())

  @@unique([userId, action, day])
  @@index([action, day])
}

model Board {
  id         Int     @id @default(autoincrement())
  slug       String  @unique
  name       String
  type       String  @default("community") // community | info | forum
  coinSymbol String?
  sortOrder  Int     @default(0)
  posts      Post[]
}

model Post {
  id           Int       @id @default(autoincrement())
  board        Board     @relation(fields: [boardId], references: [id])
  boardId      Int
  author       User      @relation(fields: [userId], references: [id])
  userId       String
  title        String
  content      String
  viewCount    Int       @default(0)
  upvotes      Int       @default(0)
  downvotes    Int       @default(0)
  commentCount Int       @default(0)
  isNotice     Boolean   @default(false)
  priceAtPost  Float?
  priceSymbol  String?
  createdAt    DateTime  @default(now())
  comments     Comment[]
  votes        Vote[]

  @@index([boardId, createdAt(sort: Desc)])
  @@index([boardId, upvotes])
}

model Comment {
  id        Int      @id @default(autoincrement())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    Int
  author    User     @relation(fields: [userId], references: [id])
  userId    String
  content   String
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

model CalendarEvent {
  id          Int      @id @default(autoincrement())
  date        DateTime
  isTba       Boolean  @default(false)
  ticker      String
  title       String
  description String
  category    String // important | good | bad | neutral (색상 분류)
  groupMain   String   @default("크립토") // 주식 | 크립토 | 매크로 | 이벤트 (필터 대분류)
  groupSub    String   @default("기타") // 필터 소분류
  sourceUrl   String?
  createdAt   DateTime @default(now())

  @@index([date])
}

model KimpSnapshot {
  id        Int      @id @default(autoincrement())
  btcKrw    Float
  btcUsd    Float
  usdKrw    Float
  kimp      Float
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Vote {
  id     Int    @id @default(autoincrement())
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId Int
  user   User   @relation(fields: [userId], references: [id])
  userId String
  value  Int

  @@unique([postId, userId])
}
